    {
      "id": "zAhpRd-0EAEZybpa6mFN_",
      "type": "text",
      "x": 144.04864065987715,
      "y": 2612.794771103632,
      "width": 610.9167175292969,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
