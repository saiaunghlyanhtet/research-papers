    {
      "id": "FAqeva7kfFJqIzj5S77zW",
      "type": "rectangle",
      "x": 317.9593876429965,
      "y": 3902.3482008434476,
      "width": 634.1666085379466,
      "height": 286.66678292410734,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
