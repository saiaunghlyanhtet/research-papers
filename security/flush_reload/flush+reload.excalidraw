    {
      "id": "ZKQUPC54JvG2hOUtfr5f-",
      "type": "text",
      "x": 898.4714965820312,
      "y": 1135.8333129882812,
      "width": 407.20001220703125,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
