      "seed": 759675153,
      "version": 641,
      "versionNonce": 1813836703,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775135103660,
      "link": null,
      "locked": false,
      "text": "1. The inclusive nature of the Intel LLC.\n\n2. The LLC must contain copies of all data in lower levels.\n\n3. If the memory line from LLC is evicted using clfush function,\nthe hardware ensures that this line is evicted from lower levels\nof other cores.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. The inclusive nature of the Intel LLC.\n\n2. The LLC must contain copies of all data in lower levels.\n\n3. If the memory line from LLC is evicted using clfush function,\nthe hardware ensures that this line is evicted from lower levels\nof other cores.",
      "autoResize": true,
      "lineHeight": 1.25
    },
