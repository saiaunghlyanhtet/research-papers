    {
      "id": "_9h-DjxBmkmCqO1A6bj6Y",
      "type": "text",
      "x": 1566.3999328613281,
      "y": 1115.333251953125,
      "width": 455.77142333984375,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
