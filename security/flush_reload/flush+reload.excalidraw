      "index": "b1S",
      "roundness": {
        "type": 3
      },
      "seed": 777148809,
      "version": 209,
      "versionNonce": 1071107209,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "JuXDJAlj_E2SEojrxtYNC",
