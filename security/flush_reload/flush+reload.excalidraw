    },
    {
      "id": "T4kXQ0OyvoX7Bz44QgCK8",
      "type": "rectangle",
      "x": 1029.2092132568362,
      "y": 3899.014983767555,
      "width": 686.6666085379466,
      "height": 286.66678292410734,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
