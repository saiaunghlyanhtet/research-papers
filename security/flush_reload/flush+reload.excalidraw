    },
    {
      "id": "-DZcwl3dVfXcJxrEl9tiC",
      "type": "rectangle",
      "x": 1290.9652818952286,
      "y": 2600.555200485956,
      "width": 483.43749999999994,
      "height": 340.5208587646484,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
