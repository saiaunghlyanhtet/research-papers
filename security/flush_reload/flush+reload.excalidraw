    {
      "id": "KuJSMzbJyd3SBMajHuOEu",
      "type": "rectangle",
      "x": 1930.8089556012833,
      "y": 2610.971918015253,
      "width": 479.7917175292969,
      "height": 346.35414123535156,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
